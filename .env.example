# ═════════════════════════════════════════════════════════════════════════
# COINTELLIGENCE ENVIRONMENT CONFIGURATION
# ═════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in the values.
# .env is NOT committed to git — it contains secrets.
#
# ═════════════════════════════════════════════════════════════════════════

# APPLICATION
# ═════════════════════════════════════════════════════════════════════════

NODE_ENV=production

NEXT_PUBLIC_SITE_URL=https://yourdomain.com
# Public URL where the site is accessible (used for OAuth redirects and OG metadata)


# ADMIN CONFIGURATION
# ═════════════════════════════════════════════════════════════════════════

ADMIN_EMAILS=admin@example.com
# Comma-separated emails allowed to access /admin (Google OAuth, case-insensitive)
# Example: ADMIN_EMAILS=richard@example.com,other@example.com


# NEXTAUTH / GOOGLE OAUTH
# ═════════════════════════════════════════════════════════════════════════

NEXTAUTH_SECRET=your-nextauth-secret-key-here
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

NEXTAUTH_URL=https://yourdomain.com
# Must match NEXT_PUBLIC_SITE_URL

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
#
# To set up Google OAuth:
# 1. Go to https://console.cloud.google.com/
# 2. Create project → Enable Google+ API
# 3. Create OAuth 2.0 credentials (Web application)
# 4. Add authorized redirect URIs:
#    - https://yourdomain.com/api/auth/callback/google
#    - http://localhost:3000/api/auth/callback/google (local dev)


# DATABASE (PostgreSQL 16)
# ═════════════════════════════════════════════════════════════════════════

POSTGRES_USER=cointelligence
POSTGRES_PASSWORD=your-secure-password-here
# Generate: openssl rand -base64 24

POSTGRES_DB=cointelligence

DATABASE_URI=postgresql://cointelligence:your-secure-password-here@db:5432/cointelligence
# HOST is 'db' (docker-compose service name), PORT is 5432 (internal)


# TRAEFIK / CLOUDFLARE ORIGIN CA
# ═════════════════════════════════════════════════════════════════════════

SITE_HOST=yourdomain.com
# Hostname Traefik routes for production traffic.
# Cloudflare Full (Strict) requires origin cert files on the VM:
#   traefik/certs/origin.crt  and  traefik/certs/origin.key
# Generate from Cloudflare → SSL/TLS → Origin Server


# ═════════════════════════════════════════════════════════════════════════
# QUICK START FOR AZURE VM
# ═════════════════════════════════════════════════════════════════════════
#
# 1. SSH into the VM and navigate to the project directory
#
# 2. Create .env file with all values filled in
#
# 3. Add Cloudflare Origin CA files:
#    $ mkdir -p traefik/certs
#    $ nano traefik/certs/origin.crt
#    $ nano traefik/certs/origin.key
#    $ chmod 644 traefik/certs/origin.crt
#    $ chmod 600 traefik/certs/origin.key
#
# 4. Start services:
#    $ docker compose pull
#    $ docker compose up -d
#
# 5. Initialize the database schema (first deploy only):
#    $ docker compose exec app npm run db:push
#
# 6. Verify:
#    $ docker compose ps
#    $ docker compose logs app
#
# ═════════════════════════════════════════════════════════════════════════
